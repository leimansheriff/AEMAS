<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AEMAS Dashboard</title>
    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-main: #ffffff;
            --text-muted: #aaaaaa;
            --accent: #bb86fc;
            --success: #03dac6;
            --danger: #cf6679;
            --warning: #f2a900;
        }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg-color); color: var(--text-main); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        h1 { color: var(--accent); margin-bottom: 5px; text-align: center; }
        .subtitle { color: var(--text-muted); margin-bottom: 30px; text-align: center; }
        
        .container { width: 100%; max-width: 600px; display: flex; flex-direction: column; gap: 20px; }
        .card { background: var(--card-bg); padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .card h2 { margin-top: 0; font-size: 1.2rem; color: var(--text-muted); border-bottom: 1px solid #333; padding-bottom: 10px; }
        
        /* Telemetry Grid */
        .telemetry-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; text-align: center; }
        .telemetry-item { background: #2a2a2a; padding: 15px; border-radius: 8px; }
        .value { font-size: 1.8rem; font-weight: bold; color: var(--success); }
        .label { font-size: 0.9rem; color: var(--text-muted); margin-top: 5px; }
        
        /* Config Section */
        .config-row { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; }
        input[type="number"] { padding: 10px; border-radius: 6px; border: 1px solid #555; background: #333; color: white; width: 100px; font-size: 1rem; }
        button { border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.2s; }
        button:active { transform: scale(0.95); }
        .btn-save { background: var(--accent); color: black; }

        /* Tab Navigation Styling */
        .tabs { display: flex; border-bottom: 2px solid #333; margin-bottom: 20px; }
        .tab { flex: 1; padding: 15px; background: transparent; color: var(--text-muted); border: none; font-size: 1.1rem; cursor: pointer; transition: 0.3s; }
        .tab:hover { background: #2a2a2a; }
        .tab.active { color: var(--accent); border-bottom: 3px solid var(--accent); font-weight: bold; background: #222; }

        /* Tab Content Visibility */
        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Centered message for Normal mode */
        .auto-message { text-align: center; padding: 30px 10px; color: var(--success); font-size: 1.2rem; background: #2a2a2a; border-radius: 8px; }
        
        /* Relays Section */
        .relay-row { display: flex; justify-content: space-between; align-items: center; background: #2a2a2a; padding: 10px 15px; border-radius: 8px; margin-bottom: 10px; }
        .controls { display: flex; gap: 10px; }
        .btn-state { background: #444; color: white; opacity: 0.8; }
        .btn-state:hover { opacity: 1; }
        .btn-on:active { background: var(--success); color: black; }
        .btn-off:active { background: var(--danger); color: white; }
        
        /* Status Log */
        .log-box { background: #000; color: #0f0; font-family: monospace; padding: 10px; border-radius: 6px; height: 80px; overflow-y: auto; font-size: 0.85rem; }
    </style>
</head>
<body>

    <h1>AEMAS Dashboard</h1>
    <div class="subtitle">Advanced Energy Management System</div>

    <div class="container">
        <div class="card">
            <h2>Live System Status</h2>
            <div class="telemetry-grid">
                <div class="telemetry-item">
                    <div class="value" id="val-voltage">--.-</div>
                    <div class="label">Voltage (V)</div>
                </div>
                <div class="telemetry-item">
                    <div class="value" id="val-soc">--</div>
                    <div class="label">Current (A)</div>
                </div>
                <div class="telemetry-item">
                    <div class="value" id="val-power">----</div>
                    <div class="label">Power (W)</div>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>Shedding Configuration</h2>
            <div class="config-row">
                <span>Load Shed Voltage Threshold:</span>
                <div>
                    <input type="number" id="input-threshold" step="0.1" placeholder="48.0">
                    <button class="btn-save" onclick="saveConfig()">Save</button>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>System Mode</h2>
            
            <div class="tabs">
                <button id="tab-normal" class="tab active" onclick="setGlobalMode('NORMAL')">Normal (Auto)</button>
                <button id="tab-override" class="tab" onclick="setGlobalMode('OVERRIDE')">User Override</button>
            </div>

            <div id="content-normal" class="tab-content active">
                <div class="auto-message">
                    ⚡ System is running automatically.<br>
                    <span style="font-size: 0.9rem; color: #aaa;">Loads will shed based on your configured voltage threshold.</span>
                </div>
            </div>

            <div id="content-override" class="tab-content">
                <div class="relay-row">
                    <span>Load 1</span>
                    <div class="controls">
                        <button id="on-1" class="btn-state btn-on" onclick="setRelay(1, 'ON')">ON</button>
                        <button id="off-1" class="btn-state btn-off" onclick="setRelay(1, 'OFF')">OFF</button>
                    </div>
                </div>
                
                <div class="relay-row">
                    <span>Load 2</span>
                    <div class="controls">
                        <button id="on-2" class="btn-state btn-on" onclick="setRelay(2, 'ON')">ON</button>
                        <button id="off-2" class="btn-state btn-off" onclick="setRelay(2, 'OFF')">OFF</button>
                    </div>
                </div>

                <div class="relay-row">
                    <span>Load 3</span>
                    <div class="controls">
                        <button id="on-3" class="btn-state btn-on" onclick="setRelay(3, 'ON')">ON</button>
                        <button id="off-3" class="btn-state btn-off" onclick="setRelay(3, 'OFF')">OFF</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>API Log</h2>
            <div id="log" class="log-box">AEMAS UI Initialized...<br></div>
        </div>
    </div>

    <script>
        // --- Helper: Write to the Log Box ---
        function logMessage(msg) {
            const logBox = document.getElementById('log');
            const time = new Date().toLocaleTimeString();
            logBox.innerHTML = `[${time}] ${msg}<br>` + logBox.innerHTML;
        }

        // --- Core 1: Fetch Telemetry (GET) ---
        async function fetchTelemetry() {
            try {
                const res = await fetch('/api/status');
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('val-voltage').innerText = data.voltage.toFixed(1);
                    document.getElementById('val-soc').innerText = data.soc.toFixed(1);
                    document.getElementById('val-power').innerText = data.power;
                }
            } catch (err) {
                console.error("Telemetry fetch failed");
            }
        }

        // --- Core 2: Save Configuration (POST) ---
        async function saveConfig() {
            const val = document.getElementById('input-threshold').value;
            if (!val) return;
            
            logMessage(`POST /api/config {"shed_voltage": ${val}}`);
            try {
                const res = await fetch('/api/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ shed_voltage: parseFloat(val) })
                });
                if(res.ok) logMessage("-> Success: Config Saved");
                else logMessage("-> Error saving config");
            } catch (err) {
                logMessage("-> Network Error");
            }
        }

        // --- Core 3: System Mode (POST) ---
        function setGlobalMode(mode) {
            // Update UI Tabs
            document.getElementById('tab-normal').classList.toggle('active', mode === 'NORMAL');
            document.getElementById('tab-override').classList.toggle('active', mode === 'OVERRIDE');
            
            document.getElementById('content-normal').classList.toggle('active', mode === 'NORMAL');
            document.getElementById('content-override').classList.toggle('active', mode === 'OVERRIDE');

            // Send command to ESP32
            logMessage(`POST /api/mode {"mode": "${mode}"}`);
            fetch('/api/mode', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mode: mode })
            }).catch(() => logMessage("-> Network Error: Could not change mode"));
        }

        // --- Core 4: Relay Commands (POST) ---
        function setRelay(loadId, state) {
            logMessage(`POST /api/relay {"load": ${loadId}, "state": "${state}"}`);
            fetch('/api/relay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ load: loadId, state: state })
            }).then(res => {
                if (res.ok) logMessage(`-> Success: Load ${loadId} turned ${state}`);
            }).catch(() => logMessage("-> Network Error"));
        }

        // --- Start the Engine ---
        fetchTelemetry();
        setInterval(fetchTelemetry, 2000);
    </script>
</body>
</html>
